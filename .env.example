# Instant Cash Offer API — defaults to same-origin /michigan-junk-cars/instant-cash-offer
# VITE_OFFER_API_URL=https://your-api-host/michigan-junk-cars/instant-cash-offer
# Leave empty unless MICHIGAN_JUNK_CARS_API_KEY is set on the server
VITE_OFFER_API_KEY=

# Website click / page-view tracking — defaults to POST /michigan-junk-cars/track-click
# VITE_TRACK_CLICK_API_URL=https://your-api-host/michigan-junk-cars/track-click
# Reuses VITE_OFFER_API_KEY when unset; optional override:
# VITE_TRACK_CLICK_API_KEY=
# Set true to enable tracking on non-michiganjunkcars.com hosts (e.g. local dev)
# VITE_TRACK_CLICK_ENABLED=true

# Form submits multipart/form-data with field "photo" (JPG/PNG/WebP, max 10 MB).
